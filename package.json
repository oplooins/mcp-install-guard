{
  "name": "mcp-install-guard",
  "version": "0.2.0-beta.11",
  "description": "Block dangerous MCP servers before you install them.",
  "type": "module",
  "bin": {
    "mcp-install-guard": "cli.mjs",
    "mcp-install-guard-gate": "gate.mjs"
  },
  "scripts": {
    "start": "node ./cli.mjs --help",
    "check": "node --check ./cli.mjs && node --check ./gate.mjs && node --check ./mcp-install-guard-proxy.mjs",
    "demo": "node ./cli.mjs --demo",
    "gate": "node ./gate.mjs --stdio-config ./sample-stdio-config.json --enforce",
    "test": "npm run check && npm run demo"
  },
  "keywords": [
    "mcp",
    "ai-security",
    "llm",
    "agent-security",
    "security",
    "cli",
    "developer-tools",
    "mcp-security"
  ],
  "author": "oplooins",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oplooins/mcp-install-guard.git"
  },
  "bugs": {
    "url": "https://github.com/oplooins/mcp-install-guard/issues"
  },
  "homepage": "https://github.com/oplooins/mcp-install-guard#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "cli.mjs",
    "gate.mjs",
    "mcp-install-guard-proxy.mjs",
    "README.md",
    "README.zh-CN.md",
    "docs/",
    ".github/actions/mcp-install-guard/action.yml"
  ]
}
